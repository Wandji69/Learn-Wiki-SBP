{
  "info": {
    "name": "Learning + Service Booking API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{base_url}}/api/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\"\n}"
        }
      }
    },
    {
      "name": "Auth Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{base_url}}/api/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
        }
      }
    },
    {
      "name": "Auth Me",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/api/auth/me"
      }
    },
    {
      "name": "Courses List",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/api/courses?filter[title]=api&sort=-created_at&per_page=10"
      }
    },
    {
      "name": "Courses Create (Admin)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{admin_token}}" }
        ],
        "url": "{{base_url}}/api/courses",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Intro to Laravel API\",\n  \"description\": \"Assessment course\",\n  \"duration_minutes\": 120\n}"
        }
      }
    },
    {
      "name": "Enroll",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{base_url}}/api/enroll",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"course_id\": 1\n}"
        }
      }
    },
    {
      "name": "Create Appointment",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{base_url}}/api/appointments",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"practitioner_name\": \"Dr. Smith\",\n  \"appointment_at\": \"2030-01-01 10:00:00\",\n  \"notes\": \"Routine check\"\n}"
        }
      }
    },
    {
      "name": "List Appointments",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/api/appointments?filter[status]=booked&sort=appointment_at&per_page=10"
      }
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000" },
    { "key": "token", "value": "" },
    { "key": "admin_token", "value": "" }
  ]
}
